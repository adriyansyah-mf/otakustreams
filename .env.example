COMPOSE_PROJECT_NAME=otakustream

# Public entrypoint (nginx)
PUBLIC_BASE_URL=https://otakunesia.com

# Postgres
POSTGRES_USER=otakustream
POSTGRES_PASSWORD=otakustream
POSTGRES_DB=otakustream
POSTGRES_HOST=postgres
POSTGRES_PORT=5432

# Redis
REDIS_URL=redis://redis:6379/0

# Celery worker (batasi beban VPS: concurrency = task paralel, prefetch = antrian per worker)
# VPS 1 vCPU / 1GB: pakai CELERY_WORKER_CONCURRENCY=1
CELERY_WORKER_CONCURRENCY=2
CELERY_WORKER_PREFETCH_MULTIPLIER=1

# API
API_PORT=8000
API_SECRET_KEY=change-me-in-prod
API_ACCESS_TOKEN_EXPIRE_MINUTES=60
API_REFRESH_TOKEN_EXPIRE_DAYS=30

# Admin bootstrap (first run)
ADMIN_EMAIL=admin@local
ADMIN_PASSWORD=admin12345

# API — CORS (production: comma-separated HTTPS origins, no spaces)
# Contoh: https://otakunesia.com,https://www.otakunesia.com
# "*" = izinkan semua origin (credentials dinonaktifkan; cocok untuk dev lokal)
CORS_ALLOWED_ORIGINS=*

# --- Next.js web (set di apps/web/.env.production / compose untuk service web) ---
# URL publik situs (wajib valid URL; dipakai metadata & canonical)
# NEXT_PUBLIC_SITE_URL=https://otakunesia.com
# Prefix API di browser: /api (nginx proxy) atau URL API penuh
# NEXT_PUBLIC_API_BASE_URL=/api
# Server-side Next → FastAPI (SSR, rewrites dev)
# INTERNAL_API_BASE_URL=http://api:8000
# Tampilkan link Admin di footer (default: tidak)
# NEXT_PUBLIC_SHOW_ADMIN_FOOTER=false

